<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_task_kpi_pivot" model="ir.ui.view">
        <field name="name">project.task.kpi.pivot</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <pivot string="Phân tích KPI Tháng" sample="1">
                <field name="department_id" type="row"/>
                <field name="user_ids" type="row"/>
                <field name="kpi_month" type="col"/>
                <field name="kpi_score" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_kpi_report_pivot" model="ir.actions.act_window">
        <field name="name">Phân tích KPI Tháng</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">pivot,graph,tree,form</field>
        <field name="domain">[('is_kpi_plan', '=', True), ('kpi_month', '!=', False)]</field>
        <field name="view_id" ref="view_project_task_kpi_pivot"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có dữ liệu đánh giá KPI nào để hiển thị!
            </p>
        </field>
    </record>
</odoo>