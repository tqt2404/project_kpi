<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_task_kpi_pivot" model="ir.ui.view">
        <field name="name">project.task.kpi.pivot</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <pivot string="Phân tích KPI Tháng" sample="1" disable_linking="True">
                <field name="department_id" type="row"/>
                <field name="user_ids" type="row"/>
                
                <field name="kpi_month" type="col"/>
                
                <field name="kpi_score" type="measure" string="Điểm KPI"/>
                <field name="kpi_target" type="measure" string="KPI Mục tiêu"/>
                <field name="kpi_actual" type="measure" string="KPI Thực tế"/>
                <field name="kpi_weight" type="measure" string="Trọng số (%)"/>

                </pivot>
        </field>
    </record>
</odoo>