<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_kpi_report_pivot" model="ir.actions.act_window">
        <field name="name">Báo cáo KPI Tháng</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">pivot,graph,tree</field>
        
        <field name="domain">[('is_kpi_plan', '=', True), ('kpi_month', '!=', False)]</field>
        
        <field name="context">{
            'create': False, 
            'edit': False, 
            'delete': False
        }</field>
        
        <field name="view_id" ref="view_project_task_kpi_pivot"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có dữ liệu đánh giá KPI nào để hiển thị!
            </p>
        </field>
    </record>

    <menuitem id="menu_project_report_kpi"
              name="Phân tích KPI"
              action="action_kpi_report_pivot"
              parent="project.menu_project_report"
              sequence="50"/>
</odoo>