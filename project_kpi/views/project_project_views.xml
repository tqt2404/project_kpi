<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_project_form_inherit_kpi" model="ir.ui.view">
        <field name="name">project.project.form.inherit.kpi</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            
            <xpath expr="//sheet" position="before">
                <header invisible="not is_kpi_plan">
                    <button name="%(project_kpi.action_project_kpi_wizard)d" 
                            type="action" 
                            string="Khởi tạo nhanh KPI Tháng" 
                            class="oe_highlight" 
                            invisible="kpi_task_count &gt;= 12"/>
                            
                    <field name="kpi_state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
            </xpath>
            
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="invisible">is_kpi_plan</attribute>
            </xpath>

            <xpath expr="//field[@name='date_start']" position="attributes">
                <attribute name="readonly">is_kpi_plan</attribute>
                <attribute name="force_save">1</attribute> 
            </xpath>
            
            <xpath expr="//field[@name='date']" position="attributes">
                <attribute name="readonly">is_kpi_plan</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>

            <xpath expr="//div[hasclass('oe_title')]" position="inside">
                <div class="o_row">
                    <field name="is_kpi_plan"/>
                    <label for="is_kpi_plan"/>
                    <field name="kpi_task_count" invisible="1"/>
                </div>
            </xpath>
            
            <xpath expr="//notebook" position="inside">
                <page string="Kế hoạch KPI" invisible="not is_kpi_plan">
                    <group>
                        <group string="Thông tin chung">
                            <field name="year" required="is_kpi_plan"/>
                            <field name="department_id" required="is_kpi_plan"/>
                        </group>
                        <group string="Kết quả">
                            <field name="kpi_year_target" required="is_kpi_plan" readonly="kpi_state != 'draft'"/>
                            <field name="kpi_allocated_weight"/>
                            
                            <field name="kpi_year_actual" string="KPI đạt được"/> 
                            <field name="kpi_completion_rate" widget="percentage"/>
                            <field name="kpi_year_score" string="Tổng điểm KPI năm"/>
                        </group>
                    </group>
                </page>
            </xpath>
            
        </field>
    </record>

    <record id="view_project_tree_inherit_kpi" model="ir.ui.view">
        <field name="name">project.project.tree.inherit.kpi</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="year" optional="show"/>
                <field name="department_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_project_project_filter_inherit_kpi" model="ir.ui.view">
        <field name="name">project.project.search.inherit.kpi</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_project_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <searchpanel>
                    <field name="department_id" string="PHÒNG BAN" icon="fa-users" select="multi" enable_counters="1"/>
                    <field name="user_id" string="NGƯỜI QUẢN LÝ" icon="fa-user" select="multi" enable_counters="1"/>
                    <field name="kpi_filter_selection" string="KẾ HOẠCH KPI" icon="fa-check-square" select="multi" enable_counters="1"/>
                </searchpanel>
            </xpath>
            <xpath expr="//filter[@name='Manager']" position="after">
                <filter string="Năm kế hoạch" name="group_by_year" context="{'group_by': 'year'}"/>
                <filter string="Phòng ban" name="group_by_department" context="{'group_by': 'department_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="project.open_view_project_all" model="ir.actions.act_window">
        <field name="view_mode">tree,kanban,form</field>
        <field name="view_id" eval="False"/>
        <field name="context">{'group_by': 'department_id', 'search_default_filter_is_kpi_plan': 1}</field>
    </record>

    <record id="project.open_view_project_all_group_stage" model="ir.actions.act_window">
        <field name="view_mode">tree,kanban,form</field>
        <field name="view_id" eval="False"/>
        <field name="context">{'group_by': 'department_id', 'search_default_filter_is_kpi_plan': 1}</field>
    </record>
</odoo>