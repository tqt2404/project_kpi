<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <record id="rule_project_task_kpi_user" model="ir.rule">
            <field name="name">Task KPI: Nhân viên chỉ xem của mình</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">['|', ('is_kpi_plan', '=', False), '&amp;', ('is_kpi_plan', '=', True), ('kpi_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        </record>

        <record id="rule_project_task_kpi_manager" model="ir.rule">
            <field name="name">Task KPI: Quản lý xem tất cả</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        </record>

    </data>
</odoo>