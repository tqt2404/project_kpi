<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="project_kpi.KpiCard" owl="1">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center">
                <div t-attf-class="bg-{{ props.color }}-light p-3 rounded me-3 text-{{ props.color }}">
                    <i t-attf-class="fa {{ props.icon }} fa-2x"/>
                </div>
                <div>
                    <h6 class="text-muted mb-1" t-esc="props.title"/>
                    <h3 class="mb-0 fw-bold" t-esc="props.value"/>
                </div>
            </div>
        </div>
    </t>
</templates>