<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_kpi_wizard_form" model="ir.ui.view">
        <field name="name">project.kpi.wizard.form</field>
        <field name="model">project.kpi.wizard</field>
        <field name="arch" type="xml">
            <form string="Khởi tạo Kế hoạch KPI">
                <sheet>
                    <group>
                        <field name="project_id" readonly="1" force_save="1"/>
                    </group>
                    <field name="line_ids">
                        <tree editable="bottom" create="0" delete="1">
                            <field name="kpi_month" force_save="1"/>
                            <field name="kpi_user_id" widget="many2one_avatar_user"/>
                            <field name="kpi_target"/>
                            <field name="kpi_weight" sum="Tổng trọng số"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button name="action_generate_kpi" string="Tạo Task KPI" type="object" class="btn-primary"/>
                    <button string="Hủy bỏ" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_project_kpi_wizard" model="ir.actions.act_window">
        <field name="name">Khởi tạo KPI nhanh</field>
        <field name="res_model">project.kpi.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field> </record>
</odoo>